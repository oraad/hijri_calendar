  "issues": {
    "sunset_unavailable": {
      "title": "সূর্যাস্ত সীমানা অনুপলব্ধ",
      "description": "Home Assistant আপনার অবস্থানের জন্য সূর্যাস্ত গণনা করতে পারেনি। স্থানীয় মধ্যরাত ব্যবহার করতে হিজরি ক্যালেন্ডার পুনরায় কনফিগার করুন, অথবা Settings → System → General-এ একটি বৈধ অবস্থান সেট করুন।"
    }
  },
  "services": {
    "calibrate_date": {
      "name": "তারিখ ক্যালিব্রেট করুন",
      "description": "আজকের জন্য ইন্টিগ্রেশন দিনের অফসেট ছোট আপেক্ষিক পরিবর্তন বা ঘোষিত হিজরি তারিখ দিয়ে সামঞ্জস্য করুন।",
      "fields": {
        "offset": {
          "name": "অফসেট সমন্বয়",
          "description": "বর্তমান ইন্টিগ্রেশন অফসেটে এই সংখ্যক দিন যোগ করুন (−2 থেকে +2)।"
        },
        "hijri": {
          "name": "হিজরি তারিখ",
          "description": "আজকের ঘোষিত হিজরি তারিখ (ISO, যেমন 1446-10-15)। প্রয়োজনীয় অফসেট গণনা করে সংরক্ষণ করে।"
        },
        "language": {
          "name": "ভাষা",
          "description": "প্রতিক্রিয়ায় ফরম্যাট করা ক্ষেত্রের ভাষা।"
        }
      }
    }
  },
